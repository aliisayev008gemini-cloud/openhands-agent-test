# LLM provider — pick one of the examples below
# OpenAI
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...

# Anthropic Claude
# LLM_MODEL=claude-sonnet-4-5
# LLM_API_KEY=sk-ant-...

# Custom / local (e.g. Ollama)
# LLM_MODEL=ollama/llama3
# LLM_BASE_URL=http://host.docker.internal:11434

# GitHub integration
GITHUB_TOKEN=ghp_...          # fine-grained PAT: issues + pull_requests read/write
GITHUB_WEBHOOK_SECRET=changeme # random string, must match the secret in your GitHub webhook settings
