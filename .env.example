# ── LiteLLM ───────────────────────────────────────────────────────────────────
# Random secret that OpenHands uses to authenticate with the LiteLLM proxy.
# Generate one with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-change-me

# Model to use — must match a model_name in litellm_config.yaml
LLM_MODEL=gpt-4o

# ── Provider API keys (only set the ones you need) ────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...           # fine-grained PAT: issues + pull_requests read/write
GITHUB_WEBHOOK_SECRET=changeme # must match the secret in your GitHub webhook settings