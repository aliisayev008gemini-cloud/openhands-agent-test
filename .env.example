# ── LiteLLM ───────────────────────────────────────────────────────────────────
# Random secret that OpenHands uses to authenticate with the LiteLLM proxy.
# Generate one with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-change-me

# Model to use — must match a model_name in litellm_config.yaml
LLM_MODEL=gpt-4o

# ── Provider API keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Add these later when needed:
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...

# ── Web UI (Caddy) ────────────────────────────────────────────────────────────
# Your domain or server IP, e.g. "openhands.example.com" or ":80" for LAN-only
CADDY_HOST=openhands.example.com

# Username shown on the login prompt
CADDY_USER=admin

# Bcrypt hash of your password.
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
# IMPORTANT: escape every $ with $$ or docker-compose will mangle the hash.
# Example: $2a$14$abc  →  $$2a$$14$$abc
CADDY_PASSWORD_HASH=$$2a$$14$$...

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...           # fine-grained PAT: issues + pull_requests read/write
GITHUB_WEBHOOK_SECRET=changeme # must match the secret in your GitHub webhook settings